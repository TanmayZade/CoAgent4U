package com.coagent4u.a2a.protocol;

/**
 * Step 1 of CAP: The requesting agent declares its intent.
 * 
 * This is sent BEFORE any data is exchanged.
 * The receiving agent's ConsentEngine evaluates this against user's rules.
 */
public record IntentDeclaration(
    String requestId,           // Unique ID for this interaction
    String fromAgent,           // Requesting agent's ID
    String toAgent,             // Target agent's ID  
    String intent,              // What: "check_availability", "schedule_meeting"
    String purpose,             // Why: "Schedule a team dinner"
    List<String> dataNeeded,    // What data: ["calendar_free_slots"]
    String requestedLevel,      // Desired sharing level: MINIMAL, STANDARD, etc.
    String signature,           // Cryptographic signature (using existing AesTokenEncryption)
    Instant timestamp
) {}
