#### [NEW] `PrivacyGuardian.java`

```java
package com.coagent4u.privacy.domain;

/**
 * The Privacy Guardian — central gatekeeper for all data flows.
 * 
 * Every piece of data that leaves the agent passes through here:
 * - Agent → Another agent (A2A/CAP)
 * - Agent → LLM (cloud model)
 * - Agent → User response (in case of sensitive context)
 */
public class PrivacyGuardian {

    private final PiiDetector piiDetector;

    /**
     * Review data before it's shared externally.
     * Returns MaskedData with PII redacted based on sharing level.
     */
    public MaskedData review(Object data, SharingLevel level, String purpose) {
        List<PiiCategory> detected = piiDetector.detect(data);
        
        return switch (level) {
            case MINIMAL  -> maskAll(data, detected);           // "Busy 3-4 PM"
            case STANDARD -> maskSensitive(data, detected);     // "Busy 3-4 PM (1 event)"
            case DETAILED -> maskPii(data, detected);           // "Meeting with Dr..." → "Meeting"
            case FULL     -> MaskedData.unmasked(data);         // Everything (trusted only)
        };
    }
}
```

#### [NEW] `PiiDetector.java`

```java
package com.coagent4u.privacy.domain;

/**
 * Detects PII in text and structured data using regex patterns.
 * 
 * Categories detected:
 * - Email addresses
 * - Phone numbers  
 * - Medical terms (appointment, doctor, hospital)
 * - Financial terms (salary, bank, account)
 * - Personal names (from calendar event titles)
 * - Addresses
 */
public class PiiDetector {
    
    private static final Map<PiiCategory, Pattern> PATTERNS = Map.of(
        PiiCategory.EMAIL,     Pattern.compile("[\\w.+-]+@[\\w-]+\\.[\\w.]+"),
        PiiCategory.PHONE,     Pattern.compile("\\+?\\d{10,13}"),
        PiiCategory.MEDICAL,   Pattern.compile("(?i)(doctor|hospital|clinic|appointment|therapy|prescription)"),
        PiiCategory.FINANCIAL, Pattern.compile("(?i)(salary|bank|account|payment|invoice)")
    );

    public List<PiiCategory> detect(Object data) {
        String text = serialize(data);
        return PATTERNS.entrySet().stream()
            .filter(e -> e.getValue().matcher(text).find())
            .map(Map.Entry::getKey)
            .toList();
    }
}
```

