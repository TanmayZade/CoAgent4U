        MSG["Slack Notifications<br/>(messaging-module)"]
    end

    subgraph "Infrastructure"
        PERSIST["PostgreSQL<br/>(persistence)"]
        SEC["JWT / AES / Rate Limiting<br/>(security)"]
        MON["Event Bus / Audit / Metrics<br/>(monitoring)"]
        CFG["Config / Profiles<br/>(config)"]
    end

    SLACK --> AGENT
    REST --> USER
    REST --> AGENT
    AGENT --> COORD
    AGENT --> APPROVAL
    AGENT --> CAL
    AGENT --> LLM
    COORD --> AGENT
    USER --> PERSIST
    AGENT --> PERSIST
    COORD --> PERSIST
    APPROVAL --> PERSIST
    AGENT --> MSG
```

