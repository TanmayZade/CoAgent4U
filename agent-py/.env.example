# CoAgent Python Agent — Environment Variables
# Copy to .env and fill in your values

# Java Bridge
JAVA_API_URL=http://localhost:8080/api/internal

# Redis
REDIS_URL=redis://localhost:6379

# LLM — Set whichever provider(s) you want to use.
# LiteLLM is model-agnostic: it routes to the right provider based on the model string.
# Examples:
#   "groq/llama-3.3-70b-versatile"
#   "openai/gpt-4o"
#   "anthropic/claude-sonnet-4-20250514"
#   "gemini/gemini-2.0-flash"
#   "ollama/llama3.2"  (local)
DEFAULT_LLM_MODEL=groq/llama-3.3-70b-versatile
PLANNING_LLM_MODEL=groq/llama-3.3-70b-versatile

# Provider API Keys (set the ones you use)
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Privacy
PII_DETECTION_ENABLED=true
DEFAULT_SHARING_LEVEL=MINIMAL
