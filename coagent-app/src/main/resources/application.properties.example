# ============================================================
# CoAgent4U — Application Properties (TEMPLATE)
# ============================================================
# Copy this file to application.properties and fill in real values.
# NEVER commit application.properties to version control.
# ============================================================

# ── Database ────────────────────────────────────────────────
spring.datasource.url=jdbc:postgresql://localhost:5432/coagent4u
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.flyway.baseline-on-migrate=true
spring.flyway.baseline-version=1
spring.flyway.schemas=public
spring.flyway.default-schema=public
spring.flyway.validate-on-migrate=false
spring.flyway.repair-on-migrate=true

spring.datasource.hikari.maximum-pool-size=5
spring.datasource.hikari.minimum-idle=1
spring.datasource.hikari.idle-timeout=30000
spring.datasource.hikari.max-lifetime=60000
spring.datasource.hikari.keepalive-time=30000

# ── Slack ───────────────────────────────────────────────────
SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
SLACK_BOT_TOKEN=xoxb-YOUR-SLACK-BOT-TOKEN
SLACK_APP_ID=YOUR_SLACK_APP_ID
SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
SLACK_REDIRECT_URI=https://YOUR_DOMAIN/auth/slack/callback

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/integrations/google/callback

# ── Security ────────────────────────────────────────────────
JWT_SECRET=GENERATE_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
AES_ENCRYPTION_KEY=GENERATE_A_BASE64_ENCODED_256_BIT_KEY

# ── LLM ─────────────────────────────────────────────────────
LLM_ENABLED=true
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# ── URLs ────────────────────────────────────────────────────
backend_url=https://YOUR_DOMAIN/
coagent.frontend-url=https://YOUR_FRONTEND_DOMAIN
