# CoAgent4U — Environment Variables Template
# Copy this file to .env and fill in real values.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/coagent4u
DATABASE_USERNAME=your-db-username
DATABASE_PASSWORD=your-db-password

# ── Slack ────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_ID=your-slack-app-id

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2/callback

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
AES_ENCRYPTION_KEY=base64-encoded-256-bit-key

# ── LLM ──────────────────────────────────────────────────────
LLM_ENABLED=true
GROQ_API_KEY=your-groq-api-key
